rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // 
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - activeTabId: string (required)
    //   - createdAt: timestamp
    //   - updatedAt: timestamp
    //
    // Collection: users/{userId}/tabs
    // Document ID: {tabId}
    // Fields:
    //   - id: string (required)
    //   - title: string (required)
    //   - type: string (required, enum: chat, settings, discovery)
    //   - createdAt: timestamp
    //
    // Collection: users/{userId}/tabs/{tabId}/messages
    // Document ID: {messageId}
    // Fields:
    //   - id: string (required)
    //   - role: string (required, enum: user, assistant, system)
    //   - content: string (required)
    //   - timestamp: timestamp
    //
    // Collection: users/{userId}/memories
    // Document ID: {memoryId}
    // Fields:
    //   - id: string (required)
    //   - type: string (required, enum: preference, fact, style, goal, resonance)
    //   - content: string (required)
    //   - strength: int (required, 1-10)
    //   - timestamp: timestamp
    //
    // Collection: users/{userId}/vault
    // Document ID: {pointerId}
    // Fields:
    //   - id: string (required)
    //   - path: string (required)
    //   - gdriveId: string (required)
    //   - encryptionHash: string (required)
    //   - size: int (required)
    //   - compressed: bool (required)
    //   - timestamp: timestamp
    //
    // Collection: users/{userId}/logs
    // Document ID: {logId}
    // Fields:
    //   - id: string (required)
    //   - type: string (required, enum: command, output, error, system, thought)
    //   - content: string (required)
    //   - timestamp: timestamp
    //   - agentId: string (optional)
    //
    // Collection: users/{userId}/sentinel/config
    // Document ID: config
    // Fields:
    //   - scanInterval: int (required, 1-24)
    //   - scanDepth: string (required, enum: quick, deep, paranoid)
    //   - active: bool (required)
    //
    // Collection: users/{userId}/sentinel/results
    // Document ID: {resultId}
    // Fields:
    //   - id: string (required)
    //   - fileName: string (required)
    //   - status: string (required, enum: clean, suspicious, malicious)
    //   - threatLevel: int (required, 0-100)
    //   - timestamp: timestamp
    //   - engine: string (required)
    //
    // Collection: users/{userId}/security/rules
    // Document ID: {ruleId}
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - naturalLanguage: string (required)
    //   - technicalBlock: string (required)
    //   - type: string (required, enum: security, operational, fiscal)
    //   - urgencyLevel: string (required, enum: standard, critical)
    //   - active: bool (required)
    //   - createdAt: timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'activeTabId']) &&
             data.uid == request.auth.uid;
    }

    function isValidTab(data) {
      return data.keys().hasAll(['id', 'title', 'type']) &&
             data.type in ['chat', 'settings', 'discovery'];
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['id', 'role', 'content', 'timestamp']) &&
             data.role in ['user', 'assistant', 'system'];
    }

    function isValidMemory(data) {
      return data.keys().hasAll(['id', 'type', 'content', 'strength', 'timestamp']) &&
             data.type in ['preference', 'fact', 'style', 'goal', 'resonance'] &&
             data.strength >= 1 && data.strength <= 10;
    }

    function isValidVaultPointer(data) {
      return data.keys().hasAll(['id', 'path', 'gdriveId', 'encryptionHash', 'size', 'compressed', 'timestamp']);
    }

    function isValidAgentLog(data) {
      return data.keys().hasAll(['id', 'type', 'content', 'timestamp']) &&
             data.type in ['command', 'output', 'error', 'system', 'thought'];
    }

    function isValidSentinelConfig(data) {
      return data.keys().hasAll(['scanInterval', 'scanDepth', 'active']) &&
             data.scanDepth in ['quick', 'deep', 'paranoid'];
    }

    function isValidScanResult(data) {
      return data.keys().hasAll(['id', 'fileName', 'status', 'threatLevel', 'timestamp', 'engine']) &&
             data.status in ['clean', 'suspicious', 'malicious'];
    }

    function isValidSecurityRule(data) {
      return data.keys().hasAll(['id', 'name', 'naturalLanguage', 'type', 'urgencyLevel', 'active', 'createdAt']) &&
             data.type in ['security', 'operational', 'fiscal'] &&
             data.urgencyLevel in ['standard', 'critical'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);

      match /tabs/{tabId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidTab(request.resource.data);
        allow update: if isOwner(userId) && isValidTab(request.resource.data);
        allow delete: if isOwner(userId);

        match /messages/{messageId} {
          allow read: if isOwner(userId);
          allow create: if isOwner(userId) && isValidMessage(request.resource.data);
        }
      }

      match /memories/{memoryId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidMemory(request.resource.data);
        allow update: if isOwner(userId) && isValidMemory(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /vault/{pointerId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidVaultPointer(request.resource.data);
        allow update: if isOwner(userId) && isValidVaultPointer(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /logs/{logId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidAgentLog(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /sentinel/config {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidSentinelConfig(request.resource.data);
      }

      match /sentinel/results/{resultId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidScanResult(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /security/rules/{ruleId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSecurityRule(request.resource.data);
        allow update: if isOwner(userId) && isValidSecurityRule(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
