# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

# VITE_GOOGLE_CLIENT_ID: The Google OAuth Client ID for your project.
# Create this in the Google Cloud Console (APIs & Services > Credentials).
# Ensure the Authorized JavaScript Origins include your APP_URL.
VITE_GOOGLE_CLIENT_ID=
