        "id": { "type": "string" },
        "locusId": { "type": "string" },
        "content": { "type": "string" },
        "sourceAgentId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "metadata": { "type": "object" }
      },
      "required": ["id", "locusId", "content", "sourceAgentId", "timestamp"]
    },
