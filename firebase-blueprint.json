      "properties": {
        "id": { "type": "string" },
        "branchId": { "type": "string" },
        "agentId": { "type": "string" },
        "permissions": { "type": "array", "items": { "type": "string" } },
        "expiresAt": { "type": "string", "format": "date-time" },
        "signature": { "type": "string" }
      },
      "required": ["id", "branchId", "agentId", "permissions", "expiresAt", "signature"]
    },
    "DispatchSession": {
      "title": "Dispatch Session",
      "description": "An active remote control session on a local branch.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "mandateId": { "type": "string" },
        "branchId": { "type": "string" },
        "agentId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed", "failed", "revoked"] },
        "logs": { "type": "array", "items": { "type": "string" } },
        "startedAt": { "type": "string", "format": "date-time" },
        "endedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "mandateId", "branchId", "agentId", "status", "startedAt"]
    },
    "MemoryRoom": {
      "title": "Memory Room",
      "description": "A high-level spatial category in the Memory Palace.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "locusCount": { "type": "number" }
      },
      "required": ["id", "name", "description", "locusCount"]
    },
    "MemoryLocus": {
      "title": "Memory Locus",
      "description": "A specific spatial point within a Memory Room.",
