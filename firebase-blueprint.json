      "properties": {
        "id": { "type": "string" },
        "topic": { "type": "string" },
        "payload": { "type": "object" },
        "publisherId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] }
      },
      "required": ["id", "topic", "publisherId", "timestamp", "priority"]
    },
    "EventSubscription": {
      "title": "Event Subscription",
      "description": "An agent's subscription to a specific event topic.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agentId": { "type": "string" },
        "topicPattern": { "type": "string" },
        "active": { "type": "boolean" },
        "lastTriggered": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "agentId", "topicPattern", "active"]
    },
    "MissionMandate": {
      "title": "Mission Mandate",
      "description": "A pre-signed authorization for an agent to control a local branch.",
