      "title": "Agent Payroll",
      "description": "Metabolic budget and payment settings for an autonomous agent.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agentId": { "type": "string" },
        "monthlyTokenLimit": { "type": "number" },
        "tokensConsumed": { "type": "number" },
