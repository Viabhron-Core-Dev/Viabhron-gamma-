{
  "entities": {
    "UserSession": {
      "title": "User Session",
      "description": "Stores user-specific app state and sessions.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "activeTabId": { "type": "string", "description": "The ID of the currently active tab." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "activeTabId"]
    },
    "Tab": {
      "title": "Tab",
      "description": "A single browser-like tab session.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "shelved", "archived"] },
        "agentId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "type", "status"]
    },
    "Chat": {
      "title": "Celestial Chat",
      "description": "A chat session in the Vaa client.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["direct", "council", "individual", "workflow", "debate", "agent", "gmail", "sentinel"] },
        "filterCategory": { "type": "string" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "type", "updatedAt"]
    },
    "Agent": {
      "title": "Sovereign Agent",
      "description": "An AI agent within the OS.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "role": { "type": "string", "enum": ["head", "executive", "contractor", "consultant", "specialized"] },
        "provider": { "type": "string" },
        "model": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive", "error"] },
        "color": { "type": "string" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "role", "provider", "model", "status"]
    },
    "FilterConfig": {
      "title": "Filter Configuration",
      "description": "User's chat filter preferences.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "active": { "type": "boolean" },
        "order": { "type": "integer" }
      },
      "required": ["id", "label", "active", "order"]
    },
    "Notification": {
      "title": "System Notification",
      "description": "A notification for the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["security", "info", "warning", "error", "system"] },
        "read": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "message", "type", "read", "timestamp"]
    },
    "Message": {
      "title": "Message",
      "description": "A message within a chat session.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant", "system"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "role", "content", "timestamp"]
    },
    "Memory": {
      "title": "Memory Fragment",
      "description": "A learned insight or preference for the AI Second Brain.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["preference", "fact", "style", "goal", "resonance"] },
        "content": { "type": "string" },
        "strength": { "type": "integer", "minimum": 1, "maximum": 10 },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "type", "content", "strength", "timestamp"]
    },
    "VaultPointer": {
      "title": "Vault Pointer",
      "description": "A reference to an encrypted, compressed file stored in Google Drive.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "path": { "type": "string" },
        "gdriveId": { "type": "string" },
        "encryptionHash": { "type": "string" },
        "size": { "type": "integer" },
        "compressed": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "path", "gdriveId", "encryptionHash", "size", "compressed", "timestamp"]
    },
    "AgentLog": {
      "title": "Agent Log",
      "description": "Execution logs for background agents.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["command", "output", "error", "system", "thought"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "agentId": { "type": "string" }
      },
      "required": ["id", "type", "content", "timestamp"]
    },
    "SentinelConfig": {
      "title": "Sentinel Configuration",
      "description": "Settings for the Sentinel Guardian antivirus.",
      "type": "object",
      "properties": {
        "scanInterval": { "type": "integer", "minimum": 1, "maximum": 24 },
        "scanDepth": { "type": "string", "enum": ["quick", "deep", "paranoid"] },
        "virusTotalApiKey": { "type": "string" },
        "active": { "type": "boolean" }
      },
      "required": ["scanInterval", "scanDepth", "active"]
    },
    "ScanResult": {
      "title": "Scan Result",
      "description": "Results of a file integrity scan.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fileName": { "type": "string" },
        "status": { "type": "string", "enum": ["clean", "suspicious", "malicious"] },
        "threatLevel": { "type": "integer", "minimum": 0, "maximum": 100 },
        "timestamp": { "type": "string", "format": "date-time" },
        "engine": { "type": "string" }
      },
      "required": ["id", "fileName", "status", "threatLevel", "timestamp", "engine"]
    },
    "SecurityRule": {
      "title": "Security Rule / Sovereign Procedure",
      "description": "A natural language rule or procedure for the agent company.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "naturalLanguage": { "type": "string", "description": "The rule in plain English." },
        "technicalBlock": { "type": "string", "description": "The technical implementation or regex." },
        "type": { "type": "string", "enum": ["security", "operational", "fiscal"] },
        "urgencyLevel": { "type": "string", "enum": ["standard", "critical"] },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "naturalLanguage", "type", "urgencyLevel", "active", "createdAt"]
    },
    "TokenGovernance": {
      "title": "Token Governance",
      "description": "Settings for managing OS-wide and extension-specific token usage.",
      "type": "object",
      "properties": {
        "globalMasterSlider": { "type": "integer", "minimum": 0, "maximum": 100 },
        "nexusSlider": { "type": "integer", "minimum": 0, "maximum": 100 },
        "emergencyBreakerEnabled": { "type": "boolean" },
        "dailyTokenLimit": { "type": "integer" },
        "currentDailyUsage": { "type": "integer" },
        "gracefulDegradationEnabled": { "type": "boolean" },
        "priorityModuleIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["globalMasterSlider", "nexusSlider", "emergencyBreakerEnabled", "dailyTokenLimit", "currentDailyUsage", "gracefulDegradationEnabled"]
    },
    "NexusSettings": {
      "title": "Nexus Settings",
      "description": "Configuration for the Viabhron Nexus private library.",
      "type": "object",
      "properties": {
        "isEnabled": { "type": "boolean" },
        "isPrivate": { "type": "boolean" },
        "allowedAgentIds": { "type": "array", "items": { "type": "string" } },
        "tokenUsageSlider": { "type": "integer", "minimum": 0, "maximum": 100 },
        "autoForkEnabled": { "type": "boolean" },
        "autonomyMandateEnabled": { "type": "boolean" }
      },
      "required": ["isEnabled", "isPrivate", "allowedAgentIds", "tokenUsageSlider", "autoForkEnabled", "autonomyMandateEnabled"]
    },
    "X402Config": {
      "title": "X402 Payment Gateway Config",
      "description": "Settings for the x402 autonomous payment system.",
      "type": "object",
      "properties": {
        "dailyLimit": { "type": "number", "minimum": 0 },
        "currentSpending": { "type": "number" },
        "provider": { "type": "string", "enum": ["coinbase", "nodit", "stripe"] },
        "active": { "type": "boolean" },
        "lastResetAt": { "type": "string", "format": "date-time" }
      },
      "required": ["dailyLimit", "currentSpending", "provider", "active"]
    },
    "X402Transaction": {
      "title": "X402 Transaction",
      "description": "A record of an autonomous payment for AI services.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "service": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "agentId": { "type": "string" }
      },
      "required": ["id", "amount", "currency", "service", "status", "timestamp"]
    },
    "SovereignIdentity": {
      "title": "Sovereign Identity (8004)",
      "description": "On-chain digital passport for an agent or user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "did": { "type": "string", "description": "Decentralized Identifier" },
        "chain": { "type": "string", "enum": ["tron", "bnb", "ethereum", "base"] },
        "address": { "type": "string" },
        "status": { "type": "string", "enum": ["unverified", "verified", "revoked"] },
        "issuedAt": { "type": "string", "format": "date-time" },
        "metadata": { "type": "object" }
      },
      "required": ["id", "did", "chain", "address", "status"]
    },
    "MultiChainConfig": {
      "title": "Multi-Chain Configuration",
      "description": "Settings for blockchain bridges and identity registrar.",
      "type": "object",
      "properties": {
        "defaultChain": { "type": "string" },
        "enabledChains": { "type": "array", "items": { "type": "string" } },
        "registrarAgentId": { "type": "string" },
        "autoVerify": { "type": "boolean" }
      },
      "required": ["defaultChain", "enabledChains", "registrarAgentId"]
    },
    "Watcher": {
      "title": "Sovereign Watcher",
      "description": "A background monitor that wakes the OS on specific events.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["LOG_REGEX", "FIRESTORE_CHANGE", "WEBHOOK", "HTTP_POLL"] },
        "target": { "type": "string", "description": "The target to monitor (URL, path, or collection)." },
        "condition": { "type": "string", "description": "The logic/regex to match." },
        "status": { "type": "string", "enum": ["active", "paused", "triggered", "error"] },
        "lastTriggered": { "type": "string", "format": "date-time" },
        "agentId": { "type": "string", "description": "The agent to wake up." },
        "priority": { "type": "integer", "minimum": 1, "maximum": 5 }
      },
      "required": ["id", "name", "type", "target", "status"]
    },
    "TranslationMetadata": {
      "title": "Translation Metadata",
      "description": "Stores translated versions of content for the Linguistic Bridge.",
      "type": "object",
      "properties": {
        "originalLanguage": { "type": "string" },
        "targetLanguage": { "type": "string" },
        "translatedText": { "type": "string" },
        "confidence": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["originalLanguage", "targetLanguage", "translatedText", "timestamp"]
    },
    "VisualAsset": {
      "title": "Visual Asset",
      "description": "An image or visual project within the Vision Lab.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "url": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "canvas_project"] },
        "layers": { "type": "array", "items": { "type": "object" } },
        "redacted": { "type": "boolean" },
        "lastEdited": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "url", "type", "lastEdited"]
    },
    "BranchHardeningStatus": {
      "title": "Branch Hardening Status",
      "description": "Status of a local branch's autonomy and QVAC inference capabilities.",
      "type": "object",
      "properties": {
        "branchId": { "type": "string" },
        "hardwareProfile": { "type": "string" },
        "qvacStatus": { "type": "string", "enum": ["active", "optimizing", "standby", "error"] },
        "metabolicSavings": { "type": "number", "description": "Tokens saved by local inference." },
        "lastHandshake": { "type": "string", "format": "date-time" }
      },
      "required": ["branchId", "qvacStatus", "lastHandshake"]
    },
    "AgentRegistryEntry": {
      "title": "Agent Registry Entry",
      "description": "An entry in the Sovereign Federated Registry for an accredited agent.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agentId": { "type": "string" },
        "name": { "type": "string" },
        "version": { "type": "string" },
        "tier": { "type": "string", "enum": ["resident", "branch", "external"] },
        "branchId": { "type": "string" },
        "status": { "type": "string", "enum": ["incubation", "auditing", "ratification", "accredited", "revoked"] },
        "accreditationId": { "type": "string" },
        "permissions": { "$ref": "AgentPermissions" },
        "lastHeartbeat": { "type": "string", "format": "date-time" },
        "metadata": { "type": "object" }
      },
      "required": ["id", "agentId", "name", "tier", "status", "permissions", "lastHeartbeat"]
    },
    "AgentPermissions": {
      "title": "Agent Permissions",
      "description": "Governance and access control settings for an agent.",
      "type": "object",
      "properties": {
        "allowedCommunicationIds": { "type": "array", "items": { "type": "string" } },
        "canAccessVault": { "type": "boolean" },
        "canAccessFiscal": { "type": "boolean" },
        "canAccessSentinel": { "type": "boolean" },
        "maxDailyTokens": { "type": "integer" },
        "isolationMode": { "type": "boolean" }
      },
      "required": ["allowedCommunicationIds", "canAccessVault", "canAccessFiscal", "canAccessSentinel", "maxDailyTokens", "isolationMode"]
    },
    "SubstrateProfile": {
      "title": "Substrate Profile",
      "description": "Hardware optimization profile for a local branch.",
      "type": "object",
      "properties": {
        "branchId": { "type": "string" },
        "gpuModel": { "type": "string" },
        "backend": { "type": "string", "enum": ["tensorrt", "torch-tensorrt", "cpu", "metal"] },
        "kvCacheEnabled": { "type": "boolean" },
        "optimizationScore": { "type": "number" },
        "lastProfiled": { "type": "string", "format": "date-time" }
      },
      "required": ["branchId", "gpuModel", "backend", "kvCacheEnabled", "lastProfiled"]
    },
    "VerificationReport": {
      "title": "Verification Report",
      "description": "A report generated by the Sovereign Verification Loop (SVL) auditor agent.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "targetFile": { "type": "string" },
        "generatorAgentId": { "type": "string" },
        "auditorAgentId": { "type": "string" },
        "status": { "type": "string", "enum": ["passed", "failed", "warning"] },
        "lintErrors": { "type": "array", "items": { "type": "string" } },
        "compileErrors": { "type": "array", "items": { "type": "string" } },
        "suggestions": { "type": "array", "items": { "type": "string" } },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "targetFile", "generatorAgentId", "auditorAgentId", "status", "timestamp"]
    },
    "SystemEvent": {
      "title": "System Event",
      "description": "An event published to the Sovereign Event Bus (SEB).",
